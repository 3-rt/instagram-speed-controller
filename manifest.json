{
  "manifest_version": 3,
  "name": "Instagram Speed Controller",
  "version": "1.0.0",
  "description": "Control playback speed of Instagram Reels and videos with overlay, hotkeys, and mouse-hold.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings.html",
  "action": {},
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
